# Required: camofox-browser REST API endpoint.
CAMOFOX_URL=http://127.0.0.1:9377

# Optional: API key if your camofox-browser requires authentication.
# CAMOFOX_API_KEY=

# Required: Feishu/Lark target — set ONE of these.
FEISHU_USER_ID=ou_xxx
# FEISHU_CHAT_ID=oc_xxx

# Optional: override lark-cli path if it is not on PATH.
# LARK_CLI_PATH=/path/to/lark-cli
